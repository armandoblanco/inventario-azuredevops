# Azure DevOps Server Configuration
# Copy this file to .env and fill in your values

# Server URL (including /tfs for on-prem installations)
# Examples:
#   https://azuredevops.company.com/tfs
#   http://tfs-server:8080/tfs
AZDO_SERVER_URL=https://your-server.company.com/tfs

# Personal Access Token (create at: https://your-server/_usersSettings/tokens)
# Required scopes: Code (Read), Work Items (Read), Build (Read), Release (Read), 
#                  Test (Read), Graph (Read), Project and Team (Read)
AZDO_PAT=your_personal_access_token_here

# Collection name (typically DefaultCollection for TFS/Azure DevOps Server)
AZDO_COLLECTION=DefaultCollection

# API Version (Azure DevOps Server 2022 supports 6.0 and 7.0)
AZDO_API_VERSION=7.0

# Output directory for inventory exports
OUTPUT_DIR=./inventarios

# Verify SSL certificates (set to False for self-signed certificates)
AZDO_VERIFY_SSL=True
