# ============================================================
# Configuracion para test-migrate.ps1
# Copia este archivo como .env y completa los valores.
# NO subas .env al repo (agregalo a .gitignore).
# ============================================================

# --- Tokens de autenticacion ---
# GitHub PAT (classic) con scopes: repo, write:org, delete_repo (opcional)
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure DevOps Server PAT con scope: Code (Read)
# Dejar vacio para usar autenticacion Windows (NTLM)
ADO_PAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Endpoints ---
ADO_BASE=https://bcrtfs/tfs/BCRCollection
GH_ORG=BCR-Devops

# --- Directorio de trabajo (ruta corta para evitar MAX_PATH en Windows) ---
WORKDIR=C:\mp
